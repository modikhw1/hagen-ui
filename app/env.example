# ===========================================
# REQUIRED - Supabase
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ===========================================
# REQUIRED - Stripe
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# REQUIRED - App Configuration
# ===========================================

NEXT_PUBLIC_APP_URL=https://your-domain.com

# ===========================================
# REQUIRED - Company Info (for invoices)
# ===========================================

NEXT_PUBLIC_COMPANY_NAME=Your Company Name
NEXT_PUBLIC_COMPANY_ORG=XXXXXX-XXXX
NEXT_PUBLIC_COMPANY_BANKGIRO=XXXX-XXXX
NEXT_PUBLIC_COMPANY_ADDRESS=Street Address
NEXT_PUBLIC_COMPANY_POSTAL=123 45 City
NEXT_PUBLIC_COMPANY_PHONE=+46 XX XXX XX XX
NEXT_PUBLIC_COMPANY_EMAIL=invoice@your-domain.com

# ===========================================
# REQUIRED - Email (Resend)
# ===========================================
# Get API key from: https://resend.com/api-keys

RESEND_API_KEY=re_...

# Optional: Custom from address (requires verified domain)
# RESEND_FROM_EMAIL=Your Company <noreply@your-domain.com>

# ===========================================
# OPTIONAL - Google Cloud Storage (for videos)
# ===========================================

GCS_CREDENTIALS_BASE64=...

# ===========================================
# OPTIONAL - Gmail (legacy email)
# ===========================================

# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
