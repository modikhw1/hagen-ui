# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# TikTok profile history — RapidAPI / tiktok-scraper7
# Required for: fetch-profile-history (per-customer) and sync-history-all (scheduled)
# Subscribe: https://rapidapi.com/tikwm-tikwm-default/api/tiktok-scraper7
RAPIDAPI_KEY=

# Scheduled sync secret
# Required for: /api/tiktok/sync, /api/cron/attention-maintenance, /api/cron/onboarding-tick
# Also used by internal cron-style routes such as POST /api/studio-v2/internal/sync-history-all.
# Must match the CRON_SECRET stored in the deployment platform for scheduled jobs.
# Generate with: openssl rand -hex 32
CRON_SECRET=


# Public app and marketing URLs
NEXT_PUBLIC_APP_URL=https://app.letrend.se
NEXT_PUBLIC_MARKETING_URL=https://letrend.se
ALLOWED_PUBLIC_ORIGINS=https://letrend.se,https://www.letrend.se

# Hagen backend
# Required for: POST /api/studio/concepts/analyze and other server-to-server Hagen routes
# Use the deployed backend URL in prod. Do not expose this as NEXT_PUBLIC_*.
# Example Railway URL: https://hagen-production.up.railway.app
HAGEN_BASE_URL=https://your-hagen-backend.example.com

# Deprecated for the /studio/concepts analyze flow.
# The browser should call same-origin /api/studio/concepts/analyze instead of talking to Hagen directly.
# Leave unset unless another legacy browser path still depends on it.
# NEXT_PUBLIC_HAGEN_API_URL=

# Optional AI enrichment for uploaded concepts
# If unset, /api/studio/concepts/enrich falls back to deterministic local enrichment.
LOVABLE_API_KEY=
LOVABLE_AI_MODEL=google/gemini-3-flash-preview

# Contact / email
CONTACT_FORM_TO_EMAIL=hej@letrend.se
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=LeTrend <hej@letrend.se>

# Stripe configuration
# The active environment is selected by STRIPE_ENV.
# Checkout now reads the publishable key from the server-side STRIPE_ENV model.
STRIPE_ENV=test

# Test
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_WEBHOOK_SECRET=whsec_...

# Live
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_LIVE_WEBHOOK_SECRET=whsec_...
